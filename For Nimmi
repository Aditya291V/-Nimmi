<!DOCTYPE html>
<html>
<head>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>For Nimmi 💖</title>

<style>
body{
    margin:0;
    height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    background:linear-gradient(135deg,#FFEAF4,#FFD6E8,#F3D9FF);
    font-family:'Poppins',sans-serif;
    overflow:hidden;
    text-align:center;
}

/* Letter Box */
.letter{
    background:white;
    padding:30px;
    width:85%;
    max-width:350px;
    border-radius:25px;
    box-shadow:0 15px 40px rgba(255,105,180,0.2);
}

/* Buttons */
button{
    padding:10px 20px;
    border:none;
    border-radius:25px;
    margin:10px;
    font-size:16px;
    cursor:pointer;
}

#openBtn,#yesBtn{ background:#FF8FAB; color:white; }
#noBtn{ background:#C77DFF; color:white; position:absolute; }

.boldText{
    font-size:40px;
    font-weight:bold;
    color:#B03060;
}

/* Floating Hearts */
.heart{
    position:absolute;
    animation:float 6s linear infinite;
}
@keyframes float{
    0%{transform:translateY(100vh); opacity:1;}
    100%{transform:translateY(-10vh); opacity:0;}
}

/* Firework */
.firework{
    position:absolute;
    width:6px;
    height:6px;
    border-radius:50%;
    animation:explode 1s ease-out forwards;
}
@keyframes explode{
    0%{transform:scale(1); opacity:1;}
    100%{transform:scale(15); opacity:0;}
}

/* Holi Powder Splash */
.splash{
    position:absolute;
    width:200px;
    height:200px;
    border-radius:50%;
    filter:blur(30px);
    opacity:0.8;
    animation:splashAnim 1s ease-out forwards;
}
@keyframes splashAnim{
    0%{transform:scale(0);}
    100%{transform:scale(2); opacity:0;}
}

</style>
</head>

<body>

<div class="letter" id="start">
    <h3>Hello Nimmi 💕</h3>
    <p>I wrote something special for you...</p>
    <button id="openBtn" onclick="openLetter()">Open 💌</button>
</div>

<audio id="bgMusic" loop>
    <source src="https://www.w3schools.com/html/horse.mp3" type="audio/mpeg">
</audio>bh

<script>

let noBtn;
let moveCount=0;

function openLetter(){
    document.getElementById("bgMusic").play();
    document.body.innerHTML =
    "<div class='letter'>"+
    "<h3>Would you like to listen me? 🌸</h3>"+
    "<button id='yesBtn' onclick='yes()'>Yes 💖</button>"+
    "<button id='noBtn' onmouseover='moveNo()'>No 😅</button>"+
    "</div>";
    noBtn=document.getElementById("noBtn");
}

function moveNo(){
    moveCount++;
    let x=Math.random()*(window.innerWidth-100);
    let y=Math.random()*(window.innerHeight-50);
    noBtn.style.left=x+"px";
    noBtn.style.top=y+"px";
    if(moveCount>6){
        alert("Sorry yaar 🥺\nPlease listen me 💕");
    }
}

function yes(){
    document.body.innerHTML =
    "<h2 style='color:#B03060;'>🌸 HAPPY HOLI 🌸</h2>"+
    "<div class='boldText'>Nimmi 💖</div>";
    createHearts();
    createFireworks();
    holiExplosion();
}

function createHearts(){
    setInterval(function(){
        let heart=document.createElement("div");
        heart.className="heart";
        heart.innerHTML="💗";
        heart.style.left=Math.random()*100+"vw";
        heart.style.fontSize=(20+Math.random()*15)+"px";
        document.body.appendChild(heart);
        setTimeout(()=>heart.remove(),6000);
    },400);
}

function createFireworks(){
    setInterval(function(){
        let fire=document.createElement("div");
        fire.className="firework";
        fire.style.background="hsl("+Math.random()*360+",100%,60%)";
        fire.style.left=Math.random()*100+"vw";
        fire.style.top=Math.random()*100+"vh";
        document.body.appendChild(fire);
        setTimeout(()=>fire.remove(),1000);
    },300);
}

/* HOLI COLOUR EXPLOSION */
function holiExplosion(){
    for(let i=0;i<15;i++){
        let splash=document.createElement("div");
        splash.className="splash";
        splash.style.background="hsl("+Math.random()*360+",100%,50%)";
        splash.style.left=Math.random()*100+"vw";
        splash.style.top=Math.random()*100+"vh";
        document.body.appendChild(splash);
        setTimeout(()=>splash.remove(),1000);
    }
}

</script>

</body>
</html>
